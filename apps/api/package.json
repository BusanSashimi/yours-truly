{
  "name": "@yours-truly/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "DATABASE_URL=postgres://yt:ytpass@localhost:5432/yours_truly_test BETTER_AUTH_SECRET=test-secret-0123456789abcdef-0123456789 S3_BUCKET=test-assets-bucket S3_REGION=us-east-1 AWS_ACCESS_KEY_ID=test-key-id AWS_SECRET_ACCESS_KEY=test-secret-key node --import tsx --test --test-concurrency=1 src/routes/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(no lint configured for api)\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^11.0.0",
    "@yours-truly/shared": "workspace:*",
    "better-auth": "^1.6.16",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
