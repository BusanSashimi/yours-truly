{
  "name": "yours-truly",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter @yours-truly/web dev",
    "dev:api": "pnpm --filter @yours-truly/api dev",
    "build": "pnpm --filter @yours-truly/shared build && pnpm --filter \"./apps/*\" build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "db:generate": "pnpm --filter @yours-truly/api db:generate",
    "db:migrate": "pnpm --filter @yours-truly/api db:migrate"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
