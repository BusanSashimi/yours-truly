# systemd EnvironmentFile for yt-api.service.
# Install as /etc/yours-truly/api.env (root:root, chmod 600 — contains secrets).
# In production, prefer sourcing these from AWS SSM Parameter Store at deploy time
# rather than a flat file on disk.

# Production (RDS): set DATABASE_CA to the RDS CA bundle and the app + migrations
# connect with verify-full (chain + hostname). RDS rejects unencrypted connections.
#   DATABASE_URL=postgres://yt:PASSWORD@yt-prod.xxxx.us-east-1.rds.amazonaws.com:5432/yours_truly
#   DATABASE_CA=/etc/yours-truly/rds-ca.pem
# Local dev: leave DATABASE_CA unset -> no SSL.
DATABASE_URL=postgres://yt:CHANGonME@localhost:5432/yours_truly
# Path to a CA bundle; when set, the DB connection uses TLS verify-full. Unset locally.
DATABASE_CA=
PORT=4000
CORS_ORIGIN=https://yourstruly.it
# Generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_ME_WITH_A_32_BYTE_HEX_SECRET
NODE_ENV=production
