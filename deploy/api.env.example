# systemd EnvironmentFile for yt-api.service.
# Install as /etc/yours-truly/api.env (root:root, chmod 600 — contains secrets).
# In production, prefer sourcing these from AWS SSM Parameter Store at deploy time
# rather than a flat file on disk.

DATABASE_URL=postgres://yt:CHANGonME@localhost:5432/yours_truly
PORT=4000
CORS_ORIGIN=https://yourstruly.it
# Generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_ME_WITH_A_32_BYTE_HEX_SECRET
NODE_ENV=production
